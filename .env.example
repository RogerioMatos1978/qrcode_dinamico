# Copie este arquivo para ".env" e ajuste os valores antes de rodar em producao.

# Chave secreta usada para assinar sessoes e tokens CSRF.
# Gere uma nova com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-por-uma-aleatoria-e-secreta

# Banco de dados.
# Para testar rapidamente sem instalar nada, deixe como esta (usa SQLite em arquivo local,
# salvo automaticamente dentro da pasta "instance/").
# Para producao com PostgreSQL, use algo como:
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/qrcode_dinamico
DATABASE_URL=sqlite:///app.db

# Dominio publico onde a aplicacao vai rodar (usado para montar os links curtos de redirecionamento).
# Ex: https://meusite.com  (sem barra no final)
BASE_URL=http://localhost:5000

# Defina como "1" quando estiver rodando atras de HTTPS em producao (ativa cookies seguros).
FORCE_HTTPS=0
